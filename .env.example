# Copy to .env for local runs, or set these as GitHub Actions repo secrets/vars.

# Required for automated synthesis (GitHub secret: ANTHROPIC_API_KEY).
# Without it, collection still runs and you generate briefs via /daily-brief.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (GitHub Actions "vars" or local env).
# Default model is claude-opus-4-8 ($5 in / $25 out per MTok).
#CLAUDE_MODEL=claude-opus-4-8
#CLAUDE_MAX_TOKENS=16000
